# Optional — use Settings UI (/settings) instead of env vars for local dev.
# Required for Docker/Compose unless each user configures credentials in the browser.
NUXT_KOBO_API_TOKEN=
# KPI base URL for v2 assets and OpenRosa submission upload (/{username}/submission).
NUXT_KOBO_BASE_URL=https://kf.kobotoolbox.org
NUXT_PUBLIC_APP_NAME=KoboFlux
# Leave empty — requests are proxied through the Nuxt server (avoids CORS).
NUXT_PUBLIC_BASE_URL=

# PostHog analytics (optional). Official Docker images include a maintainer key at build time.
# Self-hosters: set NUXT_PUBLIC_POSTHOG_ENABLED=false to opt out, or omit NUXT_PUBLIC_POSTHOG_KEY.
NUXT_PUBLIC_POSTHOG_KEY=
NUXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
NUXT_PUBLIC_POSTHOG_ENABLED=true
